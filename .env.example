# AI Team Runtime Configuration
# Copy this file to .env and fill in your values.

# ===========================================
# LLM Provider (choose one)
# ===========================================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (alternative)
# ANTHROPIC_API_KEY=

# DeepSeek (alternative)
# DEEPSEEK_API_KEY=

# ===========================================
# Server
# ===========================================
PORT=19090
NODE_ENV=production

# ===========================================
# Authentication (recommended for production)
# ===========================================
# ORCH_KICK_TOKEN=your-internal-api-secret
# DASHBOARD_TOKEN=your-dashboard-access-token

# ===========================================
# Storage
# ===========================================
TEAM_DB_PATH=/app/state/team-runtime.db
TEAM_TASK_WORKSPACE_ROOT=/app/task_workspaces

# ===========================================
# Optional: Observability
# ===========================================
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGFUSE_ENABLED=true
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# ===========================================
# Optional: Messaging Channels
# ===========================================
# TELEGRAM_BOT_TOKEN=
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
