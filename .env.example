# Server
PORT=19090
BIND=0.0.0.0
NODE_ENV=production

# Authentication
ORCH_KICK_TOKEN=replace-with-a-random-shared-secret
DASHBOARD_TOKEN=replace-with-a-random-dashboard-token
# Local dev example: http://localhost:3000
# Production: set this to your dashboard origin, e.g. https://board.example.com
DASHBOARD_CORS_ORIGIN=http://localhost:3000

# Runtime storage
TEAM_DB_PATH=./state/team-runtime.db
TEAM_TASK_WORKSPACE_ROOT=./task_workspaces

# Optional runtime toggles
TEAM_JUDGE_TRUE_EXECUTION=0
TEAM_REROUTE_JUDGE_STUB=0
TEAM_DISABLE_SSH_REMOTE_PROBE=1

# Optional host control-plane wiring
TEAM_SERVICE_ENV_UNIT=orchestrator.service
TEAM_CONTROL_PORT=19090
TEAM_CONTROL_BASE_URL=http://127.0.0.1:19090
TEAM_CONTROL_TOKEN=

# Optional model/provider credentials
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
