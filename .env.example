# AI Team Runtime Configuration
# See https://github.com/your-org/ai-team for documentation

# ===========================================
# LLM Provider Configuration
# ===========================================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# ===========================================
# Server Configuration
# ===========================================
PORT=19090
BIND=0.0.0.0
NODE_ENV=production
DASHBOARD_CORS_ORIGIN=http://localhost:3000

# ===========================================
# Authentication
# ===========================================
ORCH_KICK_TOKEN=replace-with-a-random-shared-secret
DASHBOARD_TOKEN=replace-with-a-random-dashboard-token

# ===========================================
# Runtime Storage
# ===========================================
TEAM_DB_PATH=./state/team-runtime.db
TEAM_TASK_WORKSPACE_ROOT=./task_workspaces

# ===========================================
# Optional: Observability
# ===========================================
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=ai-team
# LANGFUSE_ENABLED=true
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# ===========================================
# Optional: Messaging Channels
# ===========================================
# TELEGRAM_BOT_TOKEN=
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
