{
  "schemaVersion": "skill-manifest.v1",
  "name": "sample-skill",
  "version": "1.0.0",
  "displayName": "Sample Skill",
  "description": "Example first-class skill for AI Team Harness.",
  "author": {
    "name": "AI Team Harness"
  },
  "entry": {
    "skillMd": "SKILL.md",
    "runtime": "tools/runtime.mjs",
    "toolsDir": "tools",
    "referencesDir": "references"
  },
  "permissions": {
    "level": "restricted",
    "allow": ["read", "web_fetch"],
    "deny": ["exec"],
    "unsafe": false
  },
  "runtime": {
    "injectPrompt": true,
    "injectTools": true,
    "hooks": ["activate", "beforeTool", "afterTool"]
  },
  "keywords": ["example", "sample", "openclaw-compatible"],
  "openclaw": {
    "compatibleFormat": true
  }
}
