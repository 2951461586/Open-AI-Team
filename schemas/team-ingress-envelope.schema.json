{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/team-ingress-envelope.schema.json",
  "title": "Team Ingress Envelope",
  "type": "object",
  "required": ["kind", "payload"],
  "properties": {
    "kind": {
      "type": "string",
      "enum": ["team.async_ingress.v1", "team.visible_ingress.v1"]
    },
    "payload": {
      "type": "object",
      "required": ["messageId", "scopeKey", "originNode", "senderId"],
      "properties": {
        "messageId": { "type": "string", "minLength": 1 },
        "scopeKey": { "type": "string", "minLength": 1 },
        "deliveryTarget": { "type": "string" },
        "recipientId": { "type": "string" },
        "recipientType": { "type": "string" },
        "originNode": { "type": "string", "minLength": 1 },
        "senderId": { "type": "string", "minLength": 1 },
        "channel": { "type": "string" },
        "taskMode": { "type": "string" },
        "riskLevel": { "type": "string" },
        "text": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
