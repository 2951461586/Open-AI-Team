{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/skill-manifest.schema.json",
  "title": "AI Team Harness Skill Manifest",
  "type": "object",
  "required": ["schemaVersion", "name", "version", "entry", "permissions"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "skill-manifest.v1" },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"
    },
    "version": { "type": "string", "minLength": 1 },
    "displayName": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "author": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" }
      },
      "additionalProperties": false
    },
    "entry": {
      "type": "object",
      "required": ["skillMd"],
      "properties": {
        "skillMd": { "type": "string", "minLength": 1 },
        "runtime": { "type": "string" },
        "toolsDir": { "type": "string" },
        "referencesDir": { "type": "string" }
      },
      "additionalProperties": false
    },
    "permissions": {
      "type": "object",
      "required": ["level"],
      "properties": {
        "level": { "type": "string", "enum": ["restricted", "full"] },
        "allow": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "deny": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "unsafe": { "type": "boolean", "default": false }
      },
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "properties": {
        "injectPrompt": { "type": "boolean", "default": true },
        "injectTools": { "type": "boolean", "default": true },
        "hooks": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["install", "activate", "deactivate", "uninstall", "beforeTool", "afterTool"]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "keywords": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "openclaw": {
      "type": "object",
      "properties": {
        "compatibleFormat": { "type": "boolean", "default": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
