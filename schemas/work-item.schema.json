{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.openai-team.dev/work-item.schema.json",
  "title": "AI Team Work Item",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "objective": { "type": "string" },
    "task": { "type": "string" },
    "acceptance": { "type": "string" },
    "deliverables": { "type": "array", "items": { "type": ["string", "object"] } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "riskLevel": { "type": "string", "enum": ["low", "medium", "high"] },
    "needsReview": { "type": "boolean" },
    "needsDecision": { "type": "boolean" },
    "context": { "type": "string" },
    "preferredNode": { "type": "string" },
    "toolProfile": { "type": "string" },
    "requiredCapabilities": { "type": "array", "items": { "type": "string" } },
    "requiredSkills": { "type": "array", "items": { "type": "string" } },
    "requiredTools": { "type": "array", "items": { "type": "string" } },
    "requiredMcpServers": { "type": "array", "items": { "type": "string" } },
    "expectedContractVersion": { "type": "string" },
    "expectedOutputType": { "type": "string" },
    "timeoutMs": { "type": "integer", "minimum": 1 }
  },
  "required": ["role"]
}
