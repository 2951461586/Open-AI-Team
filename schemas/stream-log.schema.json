{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.openai-team.dev/stream-log.schema.json",
  "title": "Runtime Stream Log",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "type": { "type": "string" },
      "role": { "type": "string" },
      "label": { "type": "string" },
      "delta": { "type": "string" },
      "index": { "type": "number" },
      "total": { "type": "number" },
      "ts": { "type": "number" }
    },
    "required": ["type", "role", "label", "total", "ts"]
  }
}
