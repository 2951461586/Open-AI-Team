{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/agent-manifest.schema.json",
  "title": "AI Team Harness Agent Manifest",
  "type": "object",
  "required": ["id", "name", "version", "runtime", "hostContract", "roles"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "runtime": {
      "type": "object",
      "required": ["kind", "bootstrap", "workerEntry", "brokerEntry"],
      "properties": {
        "kind": { "type": "string" },
        "bootstrap": { "type": "string" },
        "workerEntry": { "type": "string" },
        "brokerEntry": { "type": "string" }
      },
      "additionalProperties": true
    },
    "hostContract": {
      "type": "object",
      "required": ["contractVersion", "hostAgnostic"],
      "properties": {
        "contractVersion": { "type": "string" },
        "hostAgnostic": { "type": "boolean" },
        "requires": { "type": "object" }
      },
      "additionalProperties": true
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "displayName", "contract"],
        "properties": {
          "role": { "type": "string" },
          "displayName": { "type": "string" },
          "capabilities": { "type": "array", "items": { "type": "string" } },
          "contract": { "type": "object" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
