{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.openai-team.dev/run-state.schema.json",
  "title": "Runtime Run State",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schema": { "type": "string" },
    "status": { "type": "string" },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" },
    "runId": { "type": "string" },
    "runDir": { "type": "string" },
    "userText": { "type": "string" },
    "manifest": { "type": "object" },
    "agentPackage": { "type": "object" },
    "harnessSdk": { "type": "object" },
    "contracts": { "type": "object" },
    "workQueue": { "type": ["array", "object"] },
    "currentIndex": { "type": "number" },
    "results": { "type": "array", "items": { "type": "object" } },
    "replan": { "type": ["object", "array"] },
    "continuation": { "type": ["object", "array"] },
    "crashControl": { "type": ["object", "array"] },
    "transport": { "type": "object" },
    "blackboard": { "type": ["object", "array"] },
    "durableArtifacts": { "type": "array", "items": { "type": "object" } },
    "eventLog": { "$ref": "./event-log.schema.json" },
    "toolRuns": { "type": "array", "items": { "type": "object" } },
    "decision": { "type": ["object", "null"] },
    "paths": { "type": "object" },
    "runtimeEvidence": { "type": ["object", "array"] },
    "toolRegistry": { "type": ["object", "array"] },
    "skillRegistry": { "type": ["object", "array"] },
    "injectedCapabilities": { "type": ["object", "array"] }
  },
  "required": ["schema", "status", "createdAt", "updatedAt", "runId", "runDir", "results", "paths"]
}
