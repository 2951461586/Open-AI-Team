{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.openai-team.dev/dashboard-node-summary.schema.json",
  "title": "Dashboard Node Summary",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "key": { "type": "string" },
    "label": { "type": "string" },
    "reachable": { "type": "boolean" },
    "latencyMs": { "type": "number" },
    "fallbackReady": { "type": "boolean" },
    "probe": { "type": "string" },
    "activeResidentCount": { "type": "number" },
    "activeResidentRoles": { "type": "array", "items": { "type": "string" } },
    "weight": { "type": "number" },
    "pressureReason": { "type": "string" },
    "recommended": { "type": "boolean" },
    "preferredRoles": { "type": "array", "items": { "type": "string" } },
    "fallbackRoles": { "type": "array", "items": { "type": "string" } },
    "stats": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "controlPlaneOk": { "type": "boolean" },
        "controlPlaneStatus": { "type": "string" },
        "host": { "type": "string" }
      }
    },
    "connectivity": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mode": { "type": "string" },
        "controlBaseUrl": { "type": "string" },
        "controlHost": { "type": "string" },
        "controlPort": { "type": "number" },
        "tailnetHost": { "type": "string" },
        "tailnetIp": { "type": "string" },
        "note": { "type": "string" }
      }
    }
  },
  "required": ["key", "label", "reachable"]
}
