{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.openai-team.dev/dashboard-pipeline-payload.schema.json",
  "title": "Dashboard Pipeline Payload",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "ok": { "type": "boolean" },
    "pipeline": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "taskId": { "type": "string" },
        "teamId": { "type": "string" },
        "title": { "type": "string" },
        "state": { "type": "string" },
        "phase": { "type": "string" },
        "phaseProgress": { "type": "number" },
        "estimatedCompletion": { "type": "string" },
        "currentMemberKey": { "type": "string" },
        "protocolSource": { "type": "string" },
        "deliveryClosure": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "deliverableReady": { "type": "boolean" },
            "humanInterventionReady": { "type": "boolean" },
            "deliveryStatus": { "type": "string" },
            "interventionStatus": { "type": "string" },
            "issueCount": { "type": "number" },
            "revisionCount": { "type": "number" },
            "artifactCount": { "type": "number" },
            "evidenceCount": { "type": "number" },
            "nextBestAction": { "type": "string" },
            "executiveSummary": { "type": "string" },
            "acceptanceState": { "type": "string" },
            "recommendedSurface": { "type": "string" },
            "terminalState": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "isTerminal": { "type": "boolean" },
                "terminalKind": { "type": "string" },
                "headline": { "type": "string" },
                "operatorHint": { "type": "string" },
                "archiveEligible": { "type": "boolean" },
                "archiveStatus": { "type": "string" },
                "archiveRoute": { "type": "string" }
              }
            },
            "evidenceRetrieval": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "route": { "type": "string" },
                "totalCount": { "type": "number" },
                "reviewIssueCount": { "type": "number" },
                "blockingCount": { "type": "number" },
                "recommendedSection": { "type": "string" },
                "preferredSource": { "type": "string" }
              }
            }
          }
        }
      },
      "required": ["taskId", "teamId", "state", "phase", "phaseProgress", "estimatedCompletion"]
    },
    "roles": { "type": "object" },
    "revisions": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "count": { "type": "number" },
        "maxAllowed": { "type": "number" },
        "nearLimit": { "type": "boolean" },
        "exceeded": { "type": "boolean" }
      },
      "required": ["count", "maxAllowed", "nearLimit", "exceeded"]
    },
    "issues": { "type": "object" },
    "timeline": { "type": "object" },
    "childTasks": { "type": "array", "items": { "type": "object" } },
    "executionSurface": { "type": "object" },
    "memoryLayers": { "type": ["object", "array"] },
    "artifacts": { "type": "object" },
    "evidence": { "type": "object" }
  },
  "required": ["ok", "pipeline", "roles", "revisions", "issues", "timeline", "childTasks", "executionSurface", "artifacts", "evidence"]
}
