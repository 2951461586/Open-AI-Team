{
  "version": "2.1.0",
  "output": {
    "defaultMode": "aggregated",
    "allowUserVisibleOnApprovedDoneOnly": true,
    "explicitUserVisibleSignals": ["progressUpdate", "breakthrough", "rootCause"],
    "suppressedReason": "user_visible_disabled",
    "aggregatedReason": "default_aggregate_delivery"
  },
  "visibility": {
    "defaultTaskPolicy": { "userVisible": false, "teamVisible": true },
    "defaultRequestPolicy": { "userVisible": false, "teamVisible": true }
  },
  "pipeline": {
    "stageRules": {
      "critic": {
        "required": false,
        "skipConditions": [
          { "when": "riskLevel == low", "reason": "low_risk_skip_critic" }
        ],
        "timeout": { "defaultMs": 120000, "maxMs": 300000 },
        "retry": { "maxAttempts": 1, "backoffMs": 3000 }
      },
      "judge": {
        "required": false,
        "skipConditions": [
          { "when": "riskLevel == low", "reason": "low_risk_skip_judge" }
        ],
        "timeout": { "defaultMs": 120000, "maxMs": 300000 },
        "retry": { "maxAttempts": 1, "backoffMs": 3000 }
      },
      "executor": {
        "required": true,
        "skipConditions": [],
        "timeout": { "defaultMs": 360000, "maxMs": 600000 },
        "retry": { "maxAttempts": 2, "backoffMs": 5000 }
      }
    },
    "reviewLoop": {
      "enabled": true,
      "maxRevisions": 2,
      "triggerOnVerdict": ["revise"],
      "skipOnVerdict": ["approve", "approve_with_notes"],
      "escalateOnVerdict": ["escalate_human"],
      "revisionTimeoutMs": 300000
    },
    "dynamicReplan": {
      "enabled": true,
      "maxDynamicLayers": 3,
      "maxDynamicWorkItems": 8,
      "allowedRoles": ["executor"],
      "requireTLApproval": false
    }
  },
  "singleFlight": {
    "scopeWindowMs": 1200000,
    "maxScopeTeamsToScan": 10,
    "blockTerminalStates": ["done", "cancelled"],
    "reuseActiveOnly": true,
    "followUpEventKinds": ["single_flight.hit", "single_flight.follow_up"]
  },
  "errorRecovery": {
    "autoRetry": {
      "enabled": true,
      "maxRetries": 2,
      "retryableErrors": ["timeout", "spawn_failed", "session_failed"],
      "backoffMs": 5000
    },
    "partialSuccess": {
      "enabled": true,
      "preserveCompletedResults": true,
      "retryFailedOnly": true
    },
    "degradation": {
      "enabled": true,
      "fallbackToNativeChat": true,
      "fallbackToTLDirect": true
    }
  },
  "history": {
    "mailboxScanLimit": 400,
    "routeEventLimit": 80,
    "routeArtifactLimit": 120,
    "teamRecentTaskLimit": 50,
    "activeTaskSummaryLimit": 20,
    "historyLimit": 100
  },
  "governanceRuntime": {
    "audit": {
      "enabled": true,
      "auditDir": "state/governance/audit",
      "auditLogPath": "state/governance/audit/audit.jsonl",
      "retention": { "maxEntries": 5000 }
    },
    "risk": {
      "enabled": true,
      "thresholds": {
        "mediumMin": 30,
        "highMin": 65,
        "criticalMin": 90,
        "approvalMinLevel": "high",
        "blockMinLevel": "critical"
      },
      "weights": {
        "exec": 35,
        "network": 25,
        "filesystem": 20,
        "destructive": 30,
        "privileged": 25,
        "externalWrite": 20,
        "unknownTool": 15,
        "sensitivePath": 15
      },
      "indicators": {
        "destructiveCommands": ["rm ", "mkfs", "dd ", "shutdown", "reboot", "chmod 777", "chown -R", "iptables", "ufw reset"],
        "privilegedCommands": ["sudo ", "su ", "doas "],
        "networkCommands": ["curl ", "wget ", "nc ", "ssh ", "scp ", "rsync ", "http://", "https://"],
        "sensitivePaths": ["/etc/", "/root/", "~/.ssh", ".env", "id_rsa", "authorized_keys"]
      }
    },
    "policy": {
      "enabled": true,
      "defaultDecision": "allow",
      "policyPath": "config/team/governance-policies.json",
      "hotReload": true
    },
    "approvals": {
      "requiredFor": ["high", "critical"],
      "humanQueue": "team_lead",
      "ttlMs": 900000
    }
  },
  "escalation": {
    "escalateToHuman": {
      "conditions": [
        { "when": "riskLevel == critical", "action": "block_and_notify" },
        { "when": "anyNeedsHuman == true", "action": "notify" },
        { "when": "anyFailed == true && riskLevel >= 3", "action": "notify" }
      ]
    }
  },
  "routing": {
    "strategy": "static",
    "affinityBonus": 15,
    "fallbackPolicy": "degrade_to_available",
    "nodeConstraints": {}
  },
  "lifecycle": {
    "heartbeatIntervalMs": 60000,
    "leaseDefaultMs": 300000,
    "gracePeriodMs": 90000,
    "sweepIntervalMs": 30000
  },
  "observability": {
    "emitGovernanceEvents": true,
    "emitAuditEvents": true,
    "includeRiskSummary": true
  }
}
