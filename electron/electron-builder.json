{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.aiteamharness.desktop",
  "productName": "AI Team Dashboard",
  "directories": {
    "output": "dist"
  },
  "files": [
    "main.mjs",
    "preload.mjs",
    "package.json",
    "../dashboard/out/**/*"
  ],
  "extraMetadata": {
    "main": "main.mjs"
  },
  "mac": {
    "target": [
      "dmg"
    ]
  },
  "linux": {
    "target": [
      "AppImage"
    ],
    "category": "Utility"
  },
  "win": {
    "target": [
      "nsis"
    ]
  }
}
