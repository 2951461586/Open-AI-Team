{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.ai-team.desktop",
  "productName": "AI Team",
  "copyright": "Copyright 2024-2026 AI Team",
  "directories": {
    "output": "dist",
    "buildResources": "build"
  },
  "files": [
    "main.mjs",
    "preload.mjs",
    "package.json",
    "../apps/api-server/src/**/*",
    "../dashboard/out/**/*"
  ],
  "extraMetadata": {
    "main": "main.mjs"
  },
  "asar": true,
  "compression": "maximum",
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      }
    ],
    "category": "public.app-category.developer-tools",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "darkModeSupport": true,
    "extendInfo": {
      "NSHumanReadableCopyright": "Copyright 2024-2026 AI Team"
    }
  },
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64"]
      },
      {
        "target": "deb",
        "arch": ["x64"]
      }
    ],
    "category": "Utility",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "maintainer": "AI Team",
    "vendor": "AI Team"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "publisherName": "AI Team"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "AI Team",
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico",
    "installerHeaderIcon": "build/icon.ico",
    "license": "LICENSE"
  },
  "publish": {
    "provider": "generic",
    "url": "${GITHUB_RELEASES_URL:-https://github.com/ai-team/releases/download/v}"
  }
}
